# ──────────────────────────────────────────────────────────────
# takeAway — local development environment variables
# Copy this file to .env and fill in real values for your machine.
# Never commit .env to git.
# ──────────────────────────────────────────────────────────────

NODE_ENV=development

# API
API_PORT=3000
API_HOST=0.0.0.0
API_GLOBAL_PREFIX=api

# Database (matches infra/docker-compose.yml)
DATABASE_URL=postgresql://takeaway:takeaway@localhost:5432/takeaway?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-in-prod-access
JWT_REFRESH_SECRET=change-me-in-prod-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=takeaway-dev

# Mail (Mailhog in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@takeaway.local

# 3rd-party (leave empty in local dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
MAPBOX_TOKEN=
MIXPANEL_TOKEN=
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
