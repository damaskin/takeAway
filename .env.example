# ──────────────────────────────────────────────────────────────
# takeAway — local development environment variables
# Copy this file to .env and fill in real values for your machine.
# Never commit .env to git.
# ──────────────────────────────────────────────────────────────

NODE_ENV=development

# API
API_PORT=3000
API_HOST=0.0.0.0
API_GLOBAL_PREFIX=api

# Database (matches infra/docker-compose.yml — host port 55432 to avoid
# clashing with a native Postgres install on 5432)
DATABASE_URL=postgresql://takeaway:takeaway@localhost:55432/takeaway?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-in-prod-access
JWT_REFRESH_SECRET=change-me-in-prod-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# S3 / MinIO / DigitalOcean Spaces / any S3-compatible storage.
# S3_PUBLIC_URL_BASE is optional — set when your bucket is served from a
# custom domain or CDN (e.g. https://cdn.takeaway.million-sales.ru).
# If omitted and S3_ENDPOINT is set, defaults to ${S3_ENDPOINT}/${S3_BUCKET};
# otherwise to https://${S3_BUCKET}.s3.${S3_REGION}.amazonaws.com.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=takeaway-dev
S3_PUBLIC_URL_BASE=

# Mail (Mailhog in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@takeaway.local

# 3rd-party (leave empty in local dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
MAPBOX_TOKEN=
MIXPANEL_TOKEN=
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=

# Telegram Login Widget bot username (without @). Read at build time by the
# web SPA; public value — token stays in TELEGRAM_BOT_TOKEN.
TELEGRAM_BOT_USERNAME=

# Base URL of the admin app. Used in password-reset email links so the
# recipient lands on the right host.
ADMIN_APP_URL=http://localhost:4202

# First super-admin bootstrap. Seed script reads these once to create the
# user if no SUPER_ADMIN exists yet. Leave empty in dev if you've already
# seeded a super-admin.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# ── Feature flags ─────────────────────────────────────────────────────────────
# Master switch for the M6 delivery module. Off by default — flip to `true`
# when ops is ready to launch delivery (enables dispatcher + rider UI + lets
# customers pick DELIVERY on checkout).
DELIVERY_ENABLED=false
