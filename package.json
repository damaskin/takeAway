  "scripts": {
    "nx": "nx",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "graph": "nx graph",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "dev:infra": "docker compose -f infra/docker-compose.yml up -d",
    "dev:infra:down": "docker compose -f infra/docker-compose.yml down",
    "dev:infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "prisma:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=apps/api/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=apps/api/prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "prisma:seed": "tsx apps/api/prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --schema=apps/api/prisma/schema.prisma --force",
    "prepare": "husky"
  },
  "prisma": {
    "schema": "apps/api/prisma/schema.prisma",
    "seed": "tsx apps/api/prisma/seed.ts"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml,scss,css,html}": [
      "prettier --write"
    ]
  },
