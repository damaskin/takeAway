// takeAway — Prisma schema
// Conventions (see 02_CLAUDE_PROMPT.md §7):
//   - Money: integer cents, never floats. Column type: Int.
//   - Duration: integer seconds. Column type: Int.
//   - Timestamps: UTC, column type: DateTime. UI converts to store TZ.
//   - Currency: ISO 4217 code on Brand and persisted per Store.
//
// Scope of this migration: M1 (Auth + Catalog).
// Orders / Loyalty / Payments / GiftCards tables are added in later milestones.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Locale {
  EN
  RU
}

enum Currency {
  USD
  EUR
  GBP
  AED
  THB
  IDR
}

enum DeviceType {
  IOS
  ANDROID
  WEB
  TELEGRAM
}

enum OAuthProvider {
  GOOGLE
  APPLE
  TELEGRAM
}

enum Role {
  CUSTOMER
  STAFF
  STORE_MANAGER
  BRAND_ADMIN
  SUPER_ADMIN
  RIDER
}

enum StoreStatus {
  OPEN
  CLOSED
  OVERLOADED
}

enum StoreFulfillment {
  TAKEAWAY
  DINE_IN
  DRIVE_THRU
  DELIVERY
}

enum PickupPointType {
  COUNTER
  LOCKER
  SHELF
}

enum VariationType {
  SIZE
  TEMPERATURE
  MILK
  CUP
}

enum DietTag {
  VEGAN
  VEGETARIAN
  GLUTEN_FREE
  LACTOSE_FREE
  DECAF
  SUGAR_FREE
}

enum FulfillmentType {
  PICKUP
  DINE_IN
  DELIVERY
}

enum PickupMode {
  ASAP
  SCHEDULED
}

enum OrderStatus {
  CREATED
  PAID
  ACCEPTED
  IN_PROGRESS
  READY
  PICKED_UP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  EXPIRED
}

enum OrderEventType {
  STATUS_CHANGED
  ETA_UPDATED
  CUSTOMER_NEARBY
  CUSTOMER_HERE
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND_ISSUED
  CANCELLED
  NOTE
}

enum PaymentProvider {
  STRIPE
  TELEGRAM
  APPLE_PAY
  GOOGLE_PAY
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// ─────────────────────────────────────────────────────────────────────────────
// Loyalty & Promo enums
// ─────────────────────────────────────────────────────────────────────────────

enum LoyaltyTier {
  SILVER
  GOLD
  PLATINUM
  SIGNATURE
}

/// Kind of movement in the points ledger.
/// EARN  — credited to the user (order paid, bonus, referral…)
/// SPEND — debited from the user (promo redemption, etc.)
/// EXPIRE — periodic cleanup of aged points (M3+)
/// ADJUST — manual admin correction (ticketed fix)
enum PointsEntryType {
  EARN
  SPEND
  EXPIRE
  ADJUST
}

enum PromoType {
  /// Percentage discount off subtotal (value = 0..100).
  PERCENT
  /// Flat discount in cents off subtotal.
  FIXED
  /// Cheapest qualifying item free (value = N of Y trigger; simplified M3).
  BOGO
  /// Multiply earned loyalty points by `value` (e.g. 2×).
  POINTS_MULTIPLIER
}

enum PromoStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  EXPIRED
}

/// Moderation state for a self-registered Brand.
///  * PENDING  — the owner can manage their catalog / stores, but nothing is
///               visible to customers until a SUPER_ADMIN approves.
///  * APPROVED — fully visible on the storefront.
///  * REJECTED — stays in the DB (with optional moderationNote) but is not
///               visible on the storefront and the owner can no longer add
///               new data.
enum BrandModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  phone          String?   @unique
  email          String?   @unique
  /// bcrypt hash. Staff-only (SUPER_ADMIN / BRAND_ADMIN / STORE_MANAGER /
  /// STAFF / RIDER) — CUSTOMER users authenticate via Telegram and never
  /// set a password.
  passwordHash   String?
  name           String?
  dateOfBirth    DateTime?
  avatarUrl      String?
  locale         Locale    @default(EN)
  currency       Currency  @default(USD)
  telegramUserId BigInt?   @unique
  role           Role      @default(CUSTOMER)
  blockedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  devices          Device[]
  oauthAccounts    OAuthAccount[]
  passwordResetTokens PasswordResetToken[]
  ownedBrands      Brand[] @relation("BrandOwner")
  carts            Cart[]
  orders           Order[]
  loyaltyAccount   LoyaltyAccount?
  pointsLedger     PointsLedger[]
  promoRedemptions PromoRedemption[]
  // Multi-store scope for staff/rider roles. Empty for CUSTOMER; brand-admin
  // and super-admin bypass the pivot entirely (see UserStoreScopeService).
  userStores       UserStore[]
  // Delivery orders assigned to this user (RIDER). SetNull on delete so we
  // can remove riders without wiping the order history.
  assignedDeliveries Order[]         @relation("RiderDeliveries")

  @@index([createdAt])
}

model Device {
  id         String     @id @default(cuid())
  userId     String
  type       DeviceType
  pushToken  String?
  locale     Locale     @default(EN)
  lastSeenAt DateTime   @default(now())
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([pushToken])
}

model OAuthAccount {
  id             String        @id @default(cuid())
  userId         String
  provider       OAuthProvider
  providerUserId String
  createdAt      DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

/// One-shot email-based password reset token. Hashed (SHA-256) before
/// storage — the raw value is mailed to the user once and cannot be
/// recovered server-side.
model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenancy (brands, stores)
// ─────────────────────────────────────────────────────────────────────────────

model Brand {
  id               String                @id @default(cuid())
  slug             String                @unique
  name             String
  currency         Currency              @default(USD)
  locale           Locale                @default(EN)
  logoUrl          String?
  /// Optional CSS-variable overrides applied on top of the Telegram theme
  /// in TMA (and optionally web). Shape: `{ "--color-caramel": "#aabb00" }`.
  themeOverrides   Json?
  /// Null for the demo seed brand; set on every self-registered brand.
  ownerId          String?
  moderationStatus BrandModerationStatus @default(PENDING)
  /// Free-form note the super-admin can leave when rejecting or approving.
  moderationNote   String?
  submittedAt      DateTime              @default(now())
  moderatedAt      DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  owner      User?      @relation("BrandOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  stores     Store[]
  categories Category[]
  products   Product[]
  promos     Promo[]

  @@index([moderationStatus])
  @@index([ownerId])
}

model Store {
  id                String             @id @default(cuid())
  brandId           String
  slug              String             @unique
  name              String
  addressLine       String
  city              String
  country           String
  latitude          Float
  longitude         Float
  timezone          String             @default("UTC")
  currency          Currency
  phone             String?
  email             String?
  status            StoreStatus        @default(OPEN)
  fulfillmentTypes  StoreFulfillment[]
  pickupPointType   PickupPointType    @default(COUNTER)
  // 0..100 — higher means kitchen is busier.
  busyMeter         Int                @default(0)
  // Cached ETA for an ASAP order placed now, in seconds.
  currentEtaSeconds Int                @default(600)
  minOrderCents     Int                @default(0)
  heroImageUrl      String?
  galleryUrls       String[]           @default([])
  // Per-store delivery fee overrides. All nullable — `null` means "inherit
  // the DELIVERY_FEE_* env defaults". Set on franchisees or high-density
  // stores that need their own economics.
  deliveryFeeBaseCents   Int?
  deliveryFeePerKmCents  Int?
  deliveryFreeRadiusM    Int?
  deliveryMaxRadiusM     Int?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  brand           Brand              @relation(fields: [brandId], references: [id], onDelete: Restrict)
  workingHours    StoreWorkingHour[]
  stopListEntries StopListEntry[]
  carts           Cart[]
  orders          Order[]
  userStores      UserStore[]

  @@index([brandId])
  @@index([country, city])
  @@index([latitude, longitude])
}

/// Pivot table scoping a staff user to one or more stores. Used by the
/// StoreScopeGuard so STORE_MANAGER, STAFF and RIDER users only see orders
/// and dispatch queues for stores they're assigned to. Global roles
/// (BRAND_ADMIN, SUPER_ADMIN) don't need rows — the scope service treats
/// them as "all stores".
model UserStore {
  userId    String
  storeId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
  @@index([storeId])
}

model StoreWorkingHour {
  id       String  @id @default(cuid())
  storeId  String
  // 0 = Sunday, 6 = Saturday (JS getDay() convention).
  weekday  Int
  // Minutes since local midnight, e.g. 08:30 = 510.
  opensAt  Int
  closesAt Int
  isClosed Boolean @default(false)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, weekday])
}

// ─────────────────────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id            String   @id @default(cuid())
  brandId       String
  slug          String
  name          String
  description   String?
  iconUrl       String?
  sortOrder     Int      @default(0)
  // Optional availability window — minutes since local midnight.
  availableFrom Int?
  availableTo   Int?
  visible       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([brandId, slug])
  @@index([brandId, sortOrder])
}

model Product {
  id              String    @id @default(cuid())
  brandId         String
  categoryId      String
  slug            String
  name            String
  description     String?
  basePriceCents  Int
  // Base preparation time in seconds; variations/modifiers add deltas.
  prepTimeSeconds Int       @default(180)
  caffeineLevel   Int? // 0..4 cups
  calories        Int?
  proteinsGrams   Float?
  fatsGrams       Float?
  carbsGrams      Float?
  allergens       String[]  @default([])
  dietTags        DietTag[] @default([])
  imageUrls       String[]  @default([])
  visible         Boolean   @default(true)
  sortOrder       Int       @default(0)
  // Seasonal window; null = always available.
  availableFrom   DateTime?
  availableTo     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  brand           Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category        Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variations      Variation[]
  modifiers       Modifier[]
  stopListEntries StopListEntry[]
  cartItems       CartItem[]

  @@unique([brandId, slug])
  @@index([categoryId, sortOrder])
  @@index([brandId, visible])
}

model Variation {
  id                   String        @id @default(cuid())
  productId            String
  type                 VariationType
  name                 String
  priceDeltaCents      Int           @default(0)
  prepTimeDeltaSeconds Int           @default(0)
  sortOrder            Int           @default(0)
  isDefault            Boolean       @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, type, sortOrder])
}

model Modifier {
  id                   String @id @default(cuid())
  productId            String
  slug                 String
  name                 String
  priceDeltaCents      Int    @default(0)
  prepTimeDeltaSeconds Int    @default(0)
  minCount             Int    @default(0)
  maxCount             Int    @default(1)
  sortOrder            Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, slug])
  @@index([productId, sortOrder])
}

model StopListEntry {
  id        String    @id @default(cuid())
  storeId   String
  productId String
  reason    String?
  // Optional — when to auto-restock. Null = manual re-enable.
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Cart & Order
//
// Carts are transient per (user, store). ETA is recomputed on every mutation
// based on store load + item prep times + modifier deltas.
//
// Once an order is placed, items are snapshotted into OrderItem so that
// subsequent menu/price edits do not affect placed orders.
// ─────────────────────────────────────────────────────────────────────────────

model Cart {
  id            String   @id @default(cuid())
  userId        String
  storeId       String
  subtotalCents Int      @default(0)
  etaSeconds    Int      @default(0)
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@unique([userId, storeId])
  @@index([userId])
}

model CartItem {
  id              String   @id @default(cuid())
  cartId          String
  productId       String
  quantity        Int      @default(1)
  // Resolved selections captured at add time so the cart can render without
  // a round-trip to the product catalog. Refreshed on ETA/price recompute.
  variationIds    String[] @default([])
  // Map of { modifierId: count } as a small JSON blob. Avoids a join table
  // for a tiny list and keeps writes atomic.
  modifiersJson   Json     @default("{}")
  unitPriceCents  Int
  unitPrepSeconds Int
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([cartId])
}

model Order {
  id              String          @id @default(cuid())
  userId          String
  storeId         String
  status          OrderStatus     @default(CREATED)
  fulfillmentType FulfillmentType @default(PICKUP)
  pickupMode      PickupMode      @default(ASAP)
  // UTC. For ASAP it's the moment we expect to hand it over.
  pickupAt        DateTime
  subtotalCents   Int
  discountCents   Int             @default(0)
  taxCents        Int             @default(0)
  totalCents      Int
  currency        Currency
  // 4-digit human-readable code shown to the customer and barista.
  orderCode       String          @unique
  // Opaque token embedded in the pickup QR; independent of the short code.
  qrToken         String          @unique
  paymentIntentId String?
  customerName    String?
  customerPhone   String?
  notes           String?
  couponCode      String?
  // Delivery-only fields. Mirror of address/fee kept on the Order so history
  // is immutable even if the customer's default address changes later. All
  // nullable because the PICKUP / DINE_IN path doesn't fill them.
  deliveryAddressLine String?
  deliveryCity        String?
  deliveryLatitude    Float?
  deliveryLongitude   Float?
  deliveryNotes       String?
  deliveryFeeCents    Int     @default(0)
  /// Estimated distance from store to delivery address (metres). Optional —
  /// geocoding/distance estimation is a follow-up, stored here when available.
  deliveryDistanceM   Int?
  riderId             String?
  // Status timeline — denormalized from OrderEvent for quick queries.
  createdAt       DateTime        @default(now())
  acceptedAt      DateTime?
  startedAt       DateTime?
  readyAt         DateTime?
  pickedUpAt      DateTime?
  outForDeliveryAt DateTime?
  deliveredAt      DateTime?
  cancelledAt     DateTime?
  expiredAt       DateTime?

  user            User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  store           Store            @relation(fields: [storeId], references: [id], onDelete: Restrict)
  rider           User?            @relation("RiderDeliveries", fields: [riderId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  events          OrderEvent[]
  payments        Payment[]
  pointsEntries   PointsLedger[]
  promoRedemption PromoRedemption?

  @@index([userId, createdAt])
  @@index([storeId, status])
  @@index([status, pickupAt])
  @@index([riderId, status])
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  // Full product/variations/modifiers snapshot at the moment of order
  // creation so price/stock edits do not mutate history.
  productSnapshot Json
  quantity        Int
  unitPriceCents  Int
  totalCents      Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderEvent {
  id        String         @id @default(cuid())
  orderId   String
  type      OrderEventType
  actorId   String?
  payload   Json?
  createdAt DateTime       @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model Payment {
  id            String          @id @default(cuid())
  orderId       String
  provider      PaymentProvider @default(STRIPE)
  providerRef   String? // Stripe PaymentIntent id, Telegram charge id, etc.
  status        PaymentStatus   @default(PENDING)
  amountCents   Int
  refundedCents Int             @default(0)
  currency      Currency
  rawJson       Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([providerRef])
}

// ─────────────────────────────────────────────────────────────────────────────
// Loyalty
// ─────────────────────────────────────────────────────────────────────────────

/// One row per user. Denormalized balance + current tier updated inside the
/// same transaction as ledger writes so reads stay cheap.
model LoyaltyAccount {
  id             String      @id @default(cuid())
  userId         String      @unique
  pointsBalance  Int         @default(0)
  lifetimePoints Int         @default(0)
  tier           LoyaltyTier @default(SILVER)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries PointsLedger[]

  @@index([tier])
}

/// Append-only ledger — any change to LoyaltyAccount.pointsBalance must have a
/// matching row here so we can audit / reverse / show "Recent activity".
model PointsLedger {
  id               String          @id @default(cuid())
  loyaltyAccountId String
  userId           String
  orderId          String?
  type             PointsEntryType
  // Positive for EARN/ADJUST credits, negative for SPEND/EXPIRE/ADJUST debits.
  amount           Int
  reason           String
  metadata         Json?
  createdAt        DateTime        @default(now())

  loyaltyAccount LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  order          Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([orderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Promo
// ─────────────────────────────────────────────────────────────────────────────

/// A coupon/loyalty promotion owned by a brand. Validated at checkout and
/// snapshotted onto the order so subsequent edits to the promo never rewrite
/// history.
model Promo {
  id               String      @id @default(cuid())
  brandId          String
  /// Public code the customer types. Case-insensitive unique within brand.
  code             String
  label            String
  type             PromoType
  /// For PERCENT — integer 1..100.
  /// For FIXED   — discount in cents.
  /// For BOGO    — 1 (reserved for future trigger counts).
  /// For POINTS_MULTIPLIER — multiplier ×10 (so "2.5x" = 25).
  value            Int
  /// Optional minimum cart subtotal (cents).
  minSubtotalCents Int?
  /// 0 = unlimited.
  maxRedemptions   Int         @default(0)
  perUserLimit     Int         @default(0)
  startsAt         DateTime
  endsAt           DateTime
  status           PromoStatus @default(DRAFT)
  currency         Currency    @default(USD)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  brand       Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  redemptions PromoRedemption[]

  @@unique([brandId, code])
  @@index([brandId, status])
  @@index([startsAt, endsAt])
}

model PromoRedemption {
  id            String   @id @default(cuid())
  promoId       String
  userId        String
  orderId       String   @unique
  discountCents Int
  createdAt     DateTime @default(now())

  promo Promo @relation(fields: [promoId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([promoId])
  @@index([userId])
}
