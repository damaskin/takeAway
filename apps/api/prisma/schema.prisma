// takeAway — Prisma schema
// Conventions (see 02_CLAUDE_PROMPT.md §7):
//   - Money: integer cents, never floats. Column type: Int.
//   - Duration: integer seconds. Column type: Int.
//   - Timestamps: UTC, column type: DateTime. UI converts to store TZ.
//   - Currency: ISO 4217 code on Brand and persisted per Store.
//
// Scope of this migration: M1 (Auth + Catalog).
// Orders / Loyalty / Payments / GiftCards tables are added in later milestones.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Locale {
  EN
  RU
}

enum Currency {
  USD
  EUR
  GBP
  AED
  THB
  IDR
}

enum DeviceType {
  IOS
  ANDROID
  WEB
  TELEGRAM
}

enum OAuthProvider {
  GOOGLE
  APPLE
  TELEGRAM
}

enum Role {
  CUSTOMER
  STAFF
  STORE_MANAGER
  BRAND_ADMIN
  SUPER_ADMIN
}

enum StoreStatus {
  OPEN
  CLOSED
  OVERLOADED
}

enum StoreFulfillment {
  TAKEAWAY
  DINE_IN
  DRIVE_THRU
}

enum PickupPointType {
  COUNTER
  LOCKER
  SHELF
}

enum VariationType {
  SIZE
  TEMPERATURE
  MILK
  CUP
}

enum DietTag {
  VEGAN
  VEGETARIAN
  GLUTEN_FREE
  LACTOSE_FREE
  DECAF
  SUGAR_FREE
}

enum FulfillmentType {
  PICKUP
  DINE_IN
  DELIVERY
}

enum PickupMode {
  ASAP
  SCHEDULED
}

enum OrderStatus {
  CREATED
  PAID
  ACCEPTED
  IN_PROGRESS
  READY
  PICKED_UP
  CANCELLED
  EXPIRED
}

enum OrderEventType {
  STATUS_CHANGED
  ETA_UPDATED
  CUSTOMER_NEARBY
  CUSTOMER_HERE
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND_ISSUED
  CANCELLED
  NOTE
}

enum PaymentProvider {
  STRIPE
  TELEGRAM
  APPLE_PAY
  GOOGLE_PAY
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  phone          String?   @unique
  email          String?   @unique
  name           String?
  dateOfBirth    DateTime?
  avatarUrl      String?
  locale         Locale    @default(EN)
  currency       Currency  @default(USD)
  telegramUserId BigInt?   @unique
  role           Role      @default(CUSTOMER)
  blockedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  devices       Device[]
  oauthAccounts OAuthAccount[]
  otpRequests   OtpRequest[]
  carts         Cart[]
  orders        Order[]

  @@index([createdAt])
}

model Device {
  id         String     @id @default(cuid())
  userId     String
  type       DeviceType
  pushToken  String?
  locale     Locale     @default(EN)
  lastSeenAt DateTime   @default(now())
  createdAt  DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([pushToken])
}

model OAuthAccount {
  id             String        @id @default(cuid())
  userId         String
  provider       OAuthProvider
  providerUserId String
  createdAt      DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model OtpRequest {
  id         String    @id @default(cuid())
  userId     String?
  phone      String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone, createdAt])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Tenancy (brands, stores)
// ─────────────────────────────────────────────────────────────────────────────

model Brand {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  currency  Currency @default(USD)
  locale    Locale   @default(EN)
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores     Store[]
  categories Category[]
  products   Product[]
}

model Store {
  id                String             @id @default(cuid())
  brandId           String
  slug              String             @unique
  name              String
  addressLine       String
  city              String
  country           String
  latitude          Float
  longitude         Float
  timezone          String             @default("UTC")
  currency          Currency
  phone             String?
  email             String?
  status            StoreStatus        @default(OPEN)
  fulfillmentTypes  StoreFulfillment[]
  pickupPointType   PickupPointType    @default(COUNTER)
  // 0..100 — higher means kitchen is busier.
  busyMeter         Int                @default(0)
  // Cached ETA for an ASAP order placed now, in seconds.
  currentEtaSeconds Int                @default(600)
  minOrderCents     Int                @default(0)
  heroImageUrl      String?
  galleryUrls       String[]           @default([])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  brand           Brand              @relation(fields: [brandId], references: [id], onDelete: Restrict)
  workingHours    StoreWorkingHour[]
  stopListEntries StopListEntry[]
  carts           Cart[]
  orders          Order[]

  @@index([brandId])
  @@index([country, city])
  @@index([latitude, longitude])
}

model StoreWorkingHour {
  id       String  @id @default(cuid())
  storeId  String
  // 0 = Sunday, 6 = Saturday (JS getDay() convention).
  weekday  Int
  // Minutes since local midnight, e.g. 08:30 = 510.
  opensAt  Int
  closesAt Int
  isClosed Boolean @default(false)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, weekday])
}

// ─────────────────────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id            String   @id @default(cuid())
  brandId       String
  slug          String
  name          String
  description   String?
  iconUrl       String?
  sortOrder     Int      @default(0)
  // Optional availability window — minutes since local midnight.
  availableFrom Int?
  availableTo   Int?
  visible       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([brandId, slug])
  @@index([brandId, sortOrder])
}

model Product {
  id              String    @id @default(cuid())
  brandId         String
  categoryId      String
  slug            String
  name            String
  description     String?
  basePriceCents  Int
  // Base preparation time in seconds; variations/modifiers add deltas.
  prepTimeSeconds Int       @default(180)
  caffeineLevel   Int? // 0..4 cups
  calories        Int?
  proteinsGrams   Float?
  fatsGrams       Float?
  carbsGrams      Float?
  allergens       String[]  @default([])
  dietTags        DietTag[] @default([])
  imageUrls       String[]  @default([])
  visible         Boolean   @default(true)
  sortOrder       Int       @default(0)
  // Seasonal window; null = always available.
  availableFrom   DateTime?
  availableTo     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  brand           Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category        Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variations      Variation[]
  modifiers       Modifier[]
  stopListEntries StopListEntry[]
  cartItems       CartItem[]

  @@unique([brandId, slug])
  @@index([categoryId, sortOrder])
  @@index([brandId, visible])
}

model Variation {
  id                   String        @id @default(cuid())
  productId            String
  type                 VariationType
  name                 String
  priceDeltaCents      Int           @default(0)
  prepTimeDeltaSeconds Int           @default(0)
  sortOrder            Int           @default(0)
  isDefault            Boolean       @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, type, sortOrder])
}

model Modifier {
  id                   String @id @default(cuid())
  productId            String
  slug                 String
  name                 String
  priceDeltaCents      Int    @default(0)
  prepTimeDeltaSeconds Int    @default(0)
  minCount             Int    @default(0)
  maxCount             Int    @default(1)
  sortOrder            Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, slug])
  @@index([productId, sortOrder])
}

model StopListEntry {
  id        String    @id @default(cuid())
  storeId   String
  productId String
  reason    String?
  // Optional — when to auto-restock. Null = manual re-enable.
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Cart & Order
//
// Carts are transient per (user, store). ETA is recomputed on every mutation
// based on store load + item prep times + modifier deltas.
//
// Once an order is placed, items are snapshotted into OrderItem so that
// subsequent menu/price edits do not affect placed orders.
// ─────────────────────────────────────────────────────────────────────────────

model Cart {
  id            String   @id @default(cuid())
  userId        String
  storeId       String
  subtotalCents Int      @default(0)
  etaSeconds    Int      @default(0)
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@unique([userId, storeId])
  @@index([userId])
}

model CartItem {
  id              String   @id @default(cuid())
  cartId          String
  productId       String
  quantity        Int      @default(1)
  // Resolved selections captured at add time so the cart can render without
  // a round-trip to the product catalog. Refreshed on ETA/price recompute.
  variationIds    String[] @default([])
  // Map of { modifierId: count } as a small JSON blob. Avoids a join table
  // for a tiny list and keeps writes atomic.
  modifiersJson   Json     @default("{}")
  unitPriceCents  Int
  unitPrepSeconds Int
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([cartId])
}

model Order {
  id              String          @id @default(cuid())
  userId          String
  storeId         String
  status          OrderStatus     @default(CREATED)
  fulfillmentType FulfillmentType @default(PICKUP)
  pickupMode      PickupMode      @default(ASAP)
  // UTC. For ASAP it's the moment we expect to hand it over.
  pickupAt        DateTime
  subtotalCents   Int
  discountCents   Int             @default(0)
  taxCents        Int             @default(0)
  totalCents      Int
  currency        Currency
  // 4-digit human-readable code shown to the customer and barista.
  orderCode       String          @unique
  // Opaque token embedded in the pickup QR; independent of the short code.
  qrToken         String          @unique
  paymentIntentId String?
  customerName    String?
  customerPhone   String?
  notes           String?
  couponCode      String?
  // Status timeline — denormalized from OrderEvent for quick queries.
  createdAt       DateTime        @default(now())
  acceptedAt      DateTime?
  startedAt       DateTime?
  readyAt         DateTime?
  pickedUpAt      DateTime?
  cancelledAt     DateTime?
  expiredAt       DateTime?

  user     User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  store    Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  items    OrderItem[]
  events   OrderEvent[]
  payments Payment[]

  @@index([userId, createdAt])
  @@index([storeId, status])
  @@index([status, pickupAt])
}

model OrderItem {
  id              String @id @default(cuid())
  orderId         String
  // Full product/variations/modifiers snapshot at the moment of order
  // creation so price/stock edits do not mutate history.
  productSnapshot Json
  quantity        Int
  unitPriceCents  Int
  totalCents      Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderEvent {
  id        String         @id @default(cuid())
  orderId   String
  type      OrderEventType
  actorId   String?
  payload   Json?
  createdAt DateTime       @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model Payment {
  id            String          @id @default(cuid())
  orderId       String
  provider      PaymentProvider @default(STRIPE)
  providerRef   String? // Stripe PaymentIntent id, Telegram charge id, etc.
  status        PaymentStatus   @default(PENDING)
  amountCents   Int
  refundedCents Int             @default(0)
  currency      Currency
  rawJson       Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([providerRef])
}
