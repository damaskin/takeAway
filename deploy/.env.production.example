# takeAway production environment — copy to deploy/.env.production and fill in.
# Never commit the filled-in file.

# -------- Required --------
POSTGRES_USER=takeaway
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM
POSTGRES_DB=takeaway

# 32+ byte random strings (openssl rand -hex 32). MUST differ between access & refresh.
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# -------- Recommended prod settings --------
NODE_ENV=production
LOG_LEVEL=info
API_GLOBAL_PREFIX=api

# Tighter OTP limits than dev defaults (already the prod defaults but pinned for clarity).
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_MAX_SEND_PER_HOUR=5

THROTTLER_TTL_MS=60000
THROTTLER_LIMIT=100

# Delivery feature flag — off until you're ready to launch delivery.
DELIVERY_ENABLED=false

# -------- Optional / fill in later --------

# Telegram login widget + Mini App bot token (one bot). Leave empty to disable.
TELEGRAM_BOT_TOKEN=

# Public bot username (without @) — used to render the Login Widget on web.
TELEGRAM_BOT_USERNAME=

# Base URL of the admin app — used in password-reset email links.
ADMIN_APP_URL=https://admin.takeaway.million-sales.ru

# First super-admin bootstrap (seed).
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Stripe (not used yet — leave empty).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# SMS / email / maps / analytics / monitoring — wire in as products ship.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
MAPBOX_TOKEN=
MIXPANEL_TOKEN=
SENTRY_DSN=
