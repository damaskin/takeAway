# takeAway production environment — copy to deploy/.env.production and fill in.
# Never commit the filled-in file.

# -------- Required --------
POSTGRES_USER=takeaway
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM
POSTGRES_DB=takeaway

# 32+ byte random strings (openssl rand -hex 32). MUST differ between access & refresh.
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# -------- Recommended prod settings --------
NODE_ENV=production
LOG_LEVEL=info
API_GLOBAL_PREFIX=api

# Tighter OTP limits than dev defaults (already the prod defaults but pinned for clarity).
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_MAX_SEND_PER_HOUR=5

THROTTLER_TTL_MS=60000
THROTTLER_LIMIT=100

# Delivery feature flag — off until you're ready to launch delivery.
DELIVERY_ENABLED=false

# -------- Optional / fill in later --------

# Telegram login widget + Mini App bot token (one bot). Leave empty to disable.
TELEGRAM_BOT_TOKEN=

# Public bot username (without @) — used to render the Login Widget on web.
TELEGRAM_BOT_USERNAME=

# Base URL of the admin app — used in password-reset email links.
ADMIN_APP_URL=https://admin.takeaway.million-sales.ru

# First super-admin bootstrap (seed).
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Object storage for uploaded images (brand logos, product photos later).
# Default wires the bundled MinIO container (see docker-compose.prod.yml).
# Point at AWS/Backblaze/DO-Spaces by replacing these values — the app
# doesn't care which S3-compatible backend is behind the URL.
#
# S3_ACCESS_KEY defaults to 'minioadmin'; pick a strong S3_SECRET_KEY.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME_STRONG_RANDOM
S3_BUCKET=takeaway-uploads
S3_PUBLIC_URL_BASE=https://cdn.takeaway.million-sales.ru/takeaway-uploads

# Optional: where to send MinIO console redirects (usually the CDN host).
MINIO_BROWSER_REDIRECT_URL=https://cdn.takeaway.million-sales.ru

# Stripe (not used yet — leave empty).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# SMTP for transactional mail (password reset, later receipts).
# Any SMTP provider works — Brevo / Resend / Mailgun / Postmark / your
# registrar's SMTP. Leave SMTP_HOST blank to keep MailService in log-only mode.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@takeaway.million-sales.ru

# SMS / maps / analytics / monitoring — wire in as products ship.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
MAPBOX_TOKEN=
MIXPANEL_TOKEN=
SENTRY_DSN=
